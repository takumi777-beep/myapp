<div class="mx-auto max-w-xl px-4 py-12">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-3xl font-bold text-gray-900 tracking-tight">🚀 みんなの掲示板</h1>
    <%= link_to "新規投稿する", new_post_path, class: "rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-700" %>
  </div>

  <div id="posts" class="space-y-6">
    <% @posts.each do |post| %>
      <div class="bg-white p-6 rounded-xl shadow-md border border-gray-100">
        <h2 class="text-xl font-bold text-gray-800 mb-2"><%= post.title %></h2>
        <p class="text-gray-600 mb-4"><%= post.body %></p>
        <p class="text-xs text-gray-400">投稿者: <%= post.user&.email %></p>
      </div>
    <% end %>
  </div>
</div>
