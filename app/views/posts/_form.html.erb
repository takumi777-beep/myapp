<%= form_with(model: post, class: "contents") do |form| %>
  <div class="space-y-6 max-w-md bg-white p-6 rounded-xl shadow-md border border-gray-100">
    
    <div>
      <%= form.label :title, "タイトル", class: "block text-sm font-semibold text-gray-700 mb-2" %>
      <%= form.text_field :title, class: "block w-full rounded-lg border border-gray-300 px-4 py-2 text-gray-900 focus:border-blue-500 focus:ring-blue-500" %>
    </div>

    <div>
      <%= form.label :body, "本文", class: "block text-sm font-semibold text-gray-700 mb-2" %>
      <%= form.text_area :body, rows: 4, class: "block w-full rounded-lg border border-gray-300 px-4 py-2 text-gray-900 focus:border-blue-500 focus:ring-blue-500" %>
    </div>

    <div>
      <%= form.submit "投稿する", class: "w-full rounded-lg bg-blue-600 px-4 py-2.5 text-center text-sm font-semibold text-white shadow-sm hover:bg-blue-700 cursor-pointer transition" %>
    </div>

  </div>
<% end %>
